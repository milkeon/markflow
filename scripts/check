#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

echo "▸ OpenAPI lint (apps/api/openapi.yaml)…"
pnpm openapi:lint

echo "▸ Typecheck (전 워크스페이스)…"
pnpm -r typecheck

echo "▸ Build (전 워크스페이스 — shared dist/export·계약 산출물 검증)…"
pnpm -r build

# TODO(스택 확정 후): lint 추가 — 예) pnpm -r lint
echo "✔ check 완료."
